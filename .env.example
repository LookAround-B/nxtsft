# Database
DATABASE_URL="postgresql://nxtsft:password@localhost:5432/nxtsft"

# Redis
REDIS_URL="redis://localhost:6379"

# Server
NODE_ENV="development"
PORT=3001
HOST="0.0.0.0"
LOG_LEVEL="debug"

# JWT
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRY="7d"

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ═══════════════════════════════════════════════════════════════
# PAYMENT GATEWAY - PayU (primary) + Razorpay (future)
# ═══════════════════════════════════════════════════════════════
# PayU UAT (test): https://test.payu.in/_payment
# PayU Prod:       https://secure.payu.in/_payment
PAYU_MERCHANT_KEY="XXXXXX"
PAYU_MERCHANT_SALT="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
PAYU_BASE_URL="https://test.payu.in/_payment"

# Public URL used for PayU surl/furl — must be reachable by PayU servers
# Locally: use ngrok (ngrok http 3000) and paste the https URL here
NEXT_PUBLIC_APP_URL="https://nxtsft.com"

# Razorpay (kept for future use)
RAZORPAY_KEY_ID="rzp_test_XXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXX"

# ═══════════════════════════════════════════════════════════════
# COMMUNICATIONS
# ═══════════════════════════════════════════════════════════════

# SMS via Twilio
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# WhatsApp via WATI
WATI_API_KEY="your_wati_api_key"

# Email via Resend
RESEND_API_KEY="re_XXXXXXXXXXXXXXXX"

# ═══════════════════════════════════════════════════════════════
# FILE STORAGE - Cloudflare R2
# ═══════════════════════════════════════════════════════════════
CLOUDFLARE_R2_BUCKET="nxtsft-assets"
CLOUDFLARE_R2_ACCOUNT_ID="your_account_id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your_access_key"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your_secret_key"
CLOUDFLARE_R2_PUBLIC_URL="https://nxtsft.r2.example.com"

# ═══════════════════════════════════════════════════════════════
# SEARCH ENGINE - Typesense
# ═══════════════════════════════════════════════════════════════
TYPESENSE_API_KEY="ts0be33db62dd60"
TYPESENSE_HOST="localhost:8108"

# ═══════════════════════════════════════════════════════════════
# AI/EMBEDDINGS - OpenAI
# ═══════════════════════════════════════════════════════════════
OPENAI_API_KEY="sk-XXXXXXXXXXXXXXXX"

# ═══════════════════════════════════════════════════════════════
# ANALYTICS - PostHog (product analytics)
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_POSTHOG_KEY="phc_XXXXXXXXXXXXXXXX"
POSTHOG_API_KEY="phc_XXXXXXXXXXXXXXXX"

# ═══════════════════════════════════════════════════════════════
# ERROR TRACKING - Sentry
# ═══════════════════════════════════════════════════════════════
SENTRY_DSN="https://XXXXXXX@XXXXXXX.ingest.sentry.io/XXXXXXX"

# ═══════════════════════════════════════════════════════════════
# GOOGLE SIGN-IN (OAuth) — Client ID is public; no client secret needed
# for the Google Identity button flow. Set in apps/web/.env.local locally
# and in Vercel project env (NEXT_PUBLIC_ → available at build + runtime).
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_GOOGLE_CLIENT_ID="XXXXXXXX.apps.googleusercontent.com"

# ═══════════════════════════════════════════════════════════════
# MAPS - Mapbox (property location pin + supervisor visit map)
# Public token (pk.*) ships in the browser bundle. Set in
# apps/web/.env.local locally and in the Vercel project env.
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_MAPBOX_TOKEN="pk.XXXXXXXXXXXXXXXX"

# ═══════════════════════════════════════════════════════════════
# Frontend
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_API_URL="http://localhost:3001"


UPSTASH_REDIS_REST_URL="https:...."
UPSTASH_REDIS_REST_TOKEN="gQ..."