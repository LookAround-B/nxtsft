{
  "$schema": "https://turbo.build/json-schema.json",
  "globalDependencies": ["**/.env.local", "**/.env"],
  "tasks": {
    "dev": {
      "cache": false,
      "interactive": true,
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "tsconfig.json"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"],
      "inputs": ["src/**", "package.json", "tsconfig.json"],
      "env": ["R2_ENDPOINT", "R2_ACCESS_KEY_ID", "R2_SECRET_ACCESS_KEY", "R2_BUCKET", "R2_TOKEN", "R2_PUBLIC_URL"]
    },
    "test": {
      "cache": false,
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "outputs": []
    },
    "db:migrate": {
      "cache": false,
      "inputs": ["prisma/**"]
    },
    "db:generate": {
      "cache": true,
      "inputs": ["prisma/schema.prisma"]
    }
  },
  "globalEnv": ["NODE_ENV", "DATABASE_URL", "REDIS_URL", "ENVIRONMENT", "PORT", "HOST", "CORS_ORIGINS", "NEXT_PUBLIC_API_URL"],
  "ui": "tui"
}
